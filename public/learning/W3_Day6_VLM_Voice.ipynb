    "# === 12. GPU显存计算器 ===\n",
    "# 计算不同模型配置下的GPU显存需求\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"GPU 显存计算器\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "\n",
    "def calc_model_memory(num_params_b: float, precision: str) -> float:\n",
    "    \"\"\"\n",
    "    计算模型参数占用的显存\n",
    "    num_params_b: 参数量(单位: Billion)\n",
    "    precision: FP32/FP16/INT8/INT4\n",
    "    返回: 显存(GB)\n",
    "    \"\"\"\n",
    "    bytes_per_param = {\n",
    "        \"FP32\": 4,\n",
    "        \"FP16\": 2,\n",
    "        \"BF16\": 2,\n",
    "        \"INT8\": 1,\n",
    "        \"INT4\": 0.5,\n",
    "    }\n",
    "    return num_params_b * 1e9 * bytes_per_param[precision] / 1e9\n",
    "\n",
    "\n",
    "def calc_kv_cache(num_layers: int, num_heads: int, d_head: int,\n",
    "                  seq_len: int, batch_size: int, precision: str = \"FP16\") -> float:\n",
    "    \"\"\"\n",
    "    计算KV Cache显存\n",
    "    返回: 显存(GB)\n",
    "    \"\"\"\n",
    "    bytes_per_elem = 2 if precision in [\"FP16\", \"BF16\"] else 4\n",
    "    # 2 = K和V各一份\n",
    "    kv_bytes = 2 * num_layers * num_heads * d_head * seq_len * batch_size * bytes_per_elem\n",
    "    return kv_bytes / 1e9\n",
    "\n",
    "\n",
    "def calc_activation_memory(num_layers: int, d_model: int,\n",
    "                           seq_len: int, batch_size: int) -> float:\n",
    "    \"\"\"\n",
    "    估算推理时激活值显存(FP16)\n",
    "    返回: 显存(GB)\n",
    "    \"\"\"\n",
    "    # 简化估算: 每层约 2 * d_model * seq_len * batch * 2bytes\n",
    "    act_bytes = 2 * num_layers * d_model * seq_len * batch_size * 2\n",
    "    return act_bytes / 1e9\n",
    "\n",
    "\n",
    "# --- 模型配置 ---\n",
    "model_configs = [\n",
    "    {\n",
    "        \"name\": \"LLaMA-7B\",\n",
    "        \"params_B\": 7.0,\n",
    "        \"num_layers\": 32,\n",
    "        \"num_heads\": 32,\n",
    "        \"d_head\": 128,\n",
    "        \"d_model\": 4096,\n",
    "    },\n",
    "    {\n",
    "        \"name\": \"LLaMA-13B\",\n",
    "        \"params_B\": 13.0,\n",
    "        \"num_layers\": 40,\n",
    "        \"num_heads\": 40,\n",
    "        \"d_head\": 128,\n",
    "        \"d_model\": 5120,\n",
    "    },\n",
    "    {\n",
    "        \"name\": \"LLaMA-70B\",\n",
    "        \"params_B\": 70.0,\n",
    "        \"num_layers\": 80,\n",
    "        \"num_heads\": 64,\n",
    "        \"d_head\": 128,\n",
    "        \"d_model\": 8192,\n",
    "    },\n",
    "    {\n",
    "        \"name\": \"Qwen2.5-7B\",\n",
    "        \"params_B\": 7.6,\n",
    "        \"num_layers\": 28,\n",
    "        \"num_heads\": 28,\n",
    "        \"d_head\": 128,\n",
    "        \"d_model\": 3584,\n",
    "    },\n",
    "]\n",
    "\n",
    "precisions = [\"FP16\", \"INT8\", \"INT4\"]\n",
    "seq_len = 2048\n",
    "batch_size = 1\n",
    "\n",
    "# --- 计算并展示 ---\n",
    "print(f\"\\n{'模型':15s} | {'精度':6s} | {'参数':8s} | {'KV Cache':10s} | {'激活':8s} | {'总计':8s} | {'推荐GPU'}\")\n",
    "print(\"-\" * 85)\n",
    "\n",
    "results = []\n",
    "for config in model_configs:\n",
    "    for prec in precisions:\n",
    "        model_mem = calc_model_memory(config[\"params_B\"], prec)\n",
    "        kv_mem = calc_kv_cache(config[\"num_layers\"], config[\"num_heads\"], \n",
    "                               config[\"d_head\"], seq_len, batch_size)\n",
    "        act_mem = calc_activation_memory(config[\"num_layers\"], config[\"d_model\"],\n",
    "                                         seq_len, batch_size)\n",
    "        total = model_mem + kv_mem + act_mem\n",
    "        \n",
    "        # 推荐GPU\n",
    "        if total <= 8:\n",
    "            gpu = \"RTX 3060 12GB\"\n",
    "        elif total <= 16:\n",
    "            gpu = \"RTX 4080 16GB\"\n",
    "        elif total <= 24:\n",
    "            gpu = \"RTX 3090/4090 24GB\"\n",
    "        elif total <= 48:\n",
    "            gpu = \"A6000 48GB / 2x4090\"\n",
    "        elif total <= 80:\n",
    "            gpu = \"A100 80GB\"\n",
    "        else:\n",
    "            gpu = \"多卡并行\"\n",
    "        \n",
    "        results.append({\n",
    "            \"model\": config[\"name\"],\n",
    "            \"precision\": prec,\n",
    "            \"model_mem\": model_mem,\n",
    "            \"kv_mem\": kv_mem,\n",
    "            \"act_mem\": act_mem,\n",
    "            \"total\": total,\n",
    "            \"gpu\": gpu,\n",
    "        })\n",
    "        \n",
    "        print(f\"{config['name']:15s} | {prec:6s} | {model_mem:6.1f} GB | {kv_mem:8.2f} GB | {act_mem:6.2f} GB | {total:6.1f} GB | {gpu}\")\n",
    "\n",
    "# --- 面试手算速查 ---\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"面试速算技巧\")\n",
    "print(\"=\"*60)\n",
    "print(\"\"\"\n",
    "FP16推理: 参数量(B) x 2 = 显存(GB)\n",
    "  7B  → 14 GB\n",
    "  13B → 26 GB\n",
    "  70B → 140 GB\n",
    "\n",
    "INT4推理: 参数量(B) x 0.5 = 显存(GB)\n",
    "  7B  → 3.5 GB\n",
    "  13B → 6.5 GB\n",
    "  70B → 35 GB\n",
    "\n",
    "KV Cache (seq=2048, bs=1, FP16):\n",
    "  7B  → ~1 GB\n",
    "  13B → ~1.6 GB\n",
    "  70B → ~4.2 GB\n",
    "\n",
    "口诀: FP16看参数量(B)乘2，INT4乘0.5，再加1-4G给KV Cache\n",
    "\"\"\")\n",
    "\n",
    "# --- 可视化 ---\n",
    "try:\n",
    "    import matplotlib.pyplot as plt\n",
    "    import numpy as np\n",
    "    \n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "    \n",
    "    # 左图: 不同精度的显存对比\n",
    "    models = [\"7B\", \"13B\", \"70B\"]\n",
    "    fp16_mem = [14, 26, 140]\n",
    "    int8_mem = [7, 13, 70]\n",
    "    int4_mem = [3.5, 6.5, 35]\n",
    "    \n",
    "    x = np.arange(len(models))\n",
    "    width = 0.25\n",
    "    \n",
    "    axes[0].bar(x - width, fp16_mem, width, label='FP16', color='#c2553a')\n",
    "    axes[0].bar(x, int8_mem, width, label='INT8', color='#5a6b4a')\n",
    "    axes[0].bar(x + width, int4_mem, width, label='INT4', color='#2d2a26')\n",
    "    axes[0].set_xticks(x)\n",
    "    axes[0].set_xticklabels(models)\n",
    "    axes[0].set_ylabel('显存 (GB)')\n",
    "    axes[0].set_title('不同精度的模型参数显存')\n",
    "    axes[0].legend()\n",
    "    axes[0].set_yscale('log')\n",
    "    \n",
    "    # 右图: 总显存组成(70B INT4为例)\n",
    "    labels = ['模型参数', 'KV Cache', '激活值']\n",
    "    sizes = [35, 4.2, 0.65]\n",
    "    colors = ['#c2553a', '#5a6b4a', '#2d2a26']\n",
    "    \n",
    "    axes[1].pie(sizes, labels=labels, colors=colors, autopct='%1.1f%%',\n",
    "                startangle=90)\n",
    "    axes[1].set_title('70B INT4推理 显存组成')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('memory_calc.png', dpi=100, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    print(\"[OK] 可视化已保存: memory_calc.png\")\n",
    "except ImportError:\n",
    "    print(\"[SKIP] matplotlib不可用\")\n",
    "\n",
    "print(\"\\n[练习] 请计算以下配置的显存需求:\")\n",
    "print(\"  Q: 一个7B模型，INT8量化，seq_len=4096，batch_size=4，需要多少显存？\")\n",
    "print(f\"  A: 模型 = {calc_model_memory(7, 'INT8'):.1f}GB\")\n",
    "print(f\"     KV = {calc_kv_cache(32, 32, 128, 4096, 4):.2f}GB\")\n",
    "print(f\"     总计 ≈ {calc_model_memory(7, 'INT8') + calc_kv_cache(32, 32, 128, 4096, 4):.1f}GB\")"
   ]
