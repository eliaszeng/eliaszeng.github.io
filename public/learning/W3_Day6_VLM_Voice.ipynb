    "# === 10. 语音链路代码骨架 ===\n",
    "# 构建一个模拟的VAD→ASR→LLM→TTS管道\n",
    "\n",
    "import time\n",
    "import numpy as np\n",
    "from dataclasses import dataclass\n",
    "from typing import Optional, List\n",
    "from enum import Enum\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"语音助手管道 VAD→ASR→LLM→TTS 模拟\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "\n",
    "class PipelineState(Enum):\n",
    "    IDLE = \"空闲\"\n",
    "    LISTENING = \"监听中\"\n",
    "    PROCESSING = \"处理中\"\n",
    "    SPEAKING = \"播放中\"\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class AudioChunk:\n",
    "    \"\"\"音频片段数据\"\"\"\n",
    "    data: np.ndarray\n",
    "    sample_rate: int = 16000\n",
    "    timestamp: float = 0.0\n",
    "\n",
    "\n",
    "class MockVAD:\n",
    "    \"\"\"模拟语音活动检测\"\"\"\n",
    "    def __init__(self, threshold: float = 0.5):\n",
    "        self.threshold = threshold\n",
    "        self.speech_frames = 0\n",
    "        self.silence_frames = 0\n",
    "        print(f\"  [VAD] 初始化完成, 阈值={threshold}\")\n",
    "    \n",
    "    def detect(self, audio_chunk: AudioChunk) -> dict:\n",
    "        \"\"\"检测语音活动\"\"\"\n",
    "        # 模拟: 计算音频能量\n",
    "        energy = np.mean(audio_chunk.data ** 2)\n",
    "        is_speech = energy > self.threshold\n",
    "        \n",
    "        if is_speech:\n",
    "            self.speech_frames += 1\n",
    "            self.silence_frames = 0\n",
    "        else:\n",
    "            self.silence_frames += 1\n",
    "        \n",
    "        # 停顿检测: 连续静音超过阈值认为说完\n",
    "        endpoint_detected = self.silence_frames > 10\n",
    "        \n",
    "        return {\n",
    "            \"is_speech\": is_speech,\n",
    "            \"confidence\": min(energy / self.threshold, 1.0) if is_speech else 0,\n",
    "            \"endpoint\": endpoint_detected\n",
    "        }\n",
    "\n",
    "\n",
    "class MockASR:\n",
    "    \"\"\"模拟语音识别\"\"\"\n",
    "    def __init__(self, model_size: str = \"base\"):\n",
    "        self.model_size = model_size\n",
    "        self.latency_ms = {\"tiny\": 100, \"base\": 200, \"small\": 400, \"medium\": 800}\n",
    "        print(f\"  [ASR] Whisper-{model_size} 加载完成\")\n",
    "    \n",
    "    def transcribe(self, audio_data: np.ndarray) -> str:\n",
    "        \"\"\"转录音频为文字\"\"\"\n",
    "        latency = self.latency_ms.get(self.model_size, 200)\n",
    "        time.sleep(latency / 1000)  # 模拟延迟\n",
    "        # 模拟转录结果\n",
    "        mock_texts = [\n",
    "            \"今天天气怎么样\",\n",
    "            \"帮我查一下明天的会议安排\",\n",
    "            \"请解释一下什么是transformer\",\n",
    "            \"推荐一部好看的电影\",\n",
    "        ]\n",
    "        return np.random.choice(mock_texts)\n",
    "\n",
    "\n",
    "class MockLLM:\n",
    "    \"\"\"模拟大语言模型\"\"\"\n",
    "    def __init__(self, model_name: str = \"Qwen-7B\"):\n",
    "        self.model_name = model_name\n",
    "        print(f\"  [LLM] {model_name} 加载完成\")\n",
    "    \n",
    "    def generate(self, prompt: str, stream: bool = True) -> str:\n",
    "        \"\"\"生成回复\"\"\"\n",
    "        # 模拟首token延迟\n",
    "        time.sleep(0.3)\n",
    "        \n",
    "        responses = {\n",
    "            \"今天天气怎么样\": \"今天天气晴朗，气温25度，非常适合户外活动。\",\n",
    "            \"帮我查一下明天的会议安排\": \"明天上午10点有产品评审会，下午2点有技术分享会。\",\n",
    "            \"请解释一下什么是transformer\": \"Transformer是一种基于自注意力机制的神经网络架构，它通过并行处理序列中的所有位置来捕捉长距离依赖关系。\",\n",
    "            \"推荐一部好看的电影\": \"推荐《星际穿越》，这是一部关于时间和空间的科幻巨作。\",\n",
    "        }\n",
    "        response = responses.get(prompt, \"抱歉，我不太理解你的问题。\")\n",
    "        \n",
    "        if stream:\n",
    "            # 模拟流式输出\n",
    "            tokens = list(response)\n",
    "            return response  # 简化版直接返回\n",
    "        return response\n",
    "\n",
    "\n",
    "class MockTTS:\n",
    "    \"\"\"模拟语音合成\"\"\"\n",
    "    def __init__(self, voice: str = \"default\"):\n",
    "        self.voice = voice\n",
    "        print(f\"  [TTS] 引擎初始化完成 (voice={voice})\")\n",
    "    \n",
    "    def synthesize(self, text: str) -> np.ndarray:\n",
    "        \"\"\"合成语音\"\"\"\n",
    "        # 模拟: 生成空音频\n",
    "        duration = len(text) * 0.1  # 每个字符约0.1秒\n",
    "        samples = int(duration * 16000)\n",
    "        return np.random.randn(samples) * 0.1\n",
    "\n",
    "\n",
    "# --- 组装完整管道 ---\n",
    "class VoiceAssistantPipeline:\n",
    "    \"\"\"语音助手完整管道\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        print(\"\\n初始化语音助手管道...\")\n",
    "        self.vad = MockVAD(threshold=0.3)\n",
    "        self.asr = MockASR(model_size=\"base\")\n",
    "        self.llm = MockLLM(model_name=\"Qwen-7B\")\n",
    "        self.tts = MockTTS(voice=\"default\")\n",
    "        self.state = PipelineState.IDLE\n",
    "        print(\"管道初始化完成!\\n\")\n",
    "    \n",
    "    def process_audio(self, audio_data: np.ndarray) -> dict:\n",
    "        \"\"\"处理一段音频输入\"\"\"\n",
    "        result = {\"stages\": {}, \"total_latency_ms\": 0}\n",
    "        \n",
    "        # Stage 1: VAD\n",
    "        self.state = PipelineState.LISTENING\n",
    "        t0 = time.time()\n",
    "        chunk = AudioChunk(data=audio_data)\n",
    "        vad_result = self.vad.detect(chunk)\n",
    "        vad_ms = (time.time() - t0) * 1000\n",
    "        result[\"stages\"][\"VAD\"] = {\"latency_ms\": vad_ms, \"is_speech\": vad_result[\"is_speech\"]}\n",
    "        \n",
    "        if not vad_result[\"is_speech\"]:\n",
    "            print(\"  [VAD] 未检测到语音，跳过\")\n",
    "            return result\n",
    "        \n",
    "        # Stage 2: ASR\n",
    "        t0 = time.time()\n",
    "        text = self.asr.transcribe(audio_data)\n",
    "        asr_ms = (time.time() - t0) * 1000\n",
    "        result[\"stages\"][\"ASR\"] = {\"latency_ms\": asr_ms, \"text\": text}\n",
    "        \n",
    "        # Stage 3: LLM\n",
    "        self.state = PipelineState.PROCESSING\n",
    "        t0 = time.time()\n",
    "        response = self.llm.generate(text)\n",
    "        llm_ms = (time.time() - t0) * 1000\n",
    "        result[\"stages\"][\"LLM\"] = {\"latency_ms\": llm_ms, \"response\": response}\n",
    "        \n",
    "        # Stage 4: TTS\n",
    "        self.state = PipelineState.SPEAKING\n",
    "        t0 = time.time()\n",
    "        audio_out = self.tts.synthesize(response)\n",
    "        tts_ms = (time.time() - t0) * 1000\n",
    "        result[\"stages\"][\"TTS\"] = {\"latency_ms\": tts_ms, \"audio_len\": len(audio_out)}\n",
    "        \n",
    "        # 汇总\n",
    "        result[\"total_latency_ms\"] = vad_ms + asr_ms + llm_ms + tts_ms\n",
    "        self.state = PipelineState.IDLE\n",
    "        \n",
    "        return result\n",
    "\n",
    "\n",
    "# --- 运行演示 ---\n",
    "pipeline = VoiceAssistantPipeline()\n",
    "\n",
    "# 模拟用户说话\n",
    "print(\"模拟用户输入音频...\")\n",
    "fake_audio = np.random.randn(16000) * 0.8  # 1秒音频，高能量\n",
    "\n",
    "result = pipeline.process_audio(fake_audio)\n",
    "\n",
    "print(\"\\n\" + \"-\"*50)\n",
    "print(\"处理结果:\")\n",
    "for stage, info in result[\"stages\"].items():\n",
    "    print(f\"  {stage}: {info}\")\n",
    "print(f\"  总延迟: {result['total_latency_ms']:.1f}ms\")\n",
    "print(\"-\"*50)\n",
    "\n",
    "# --- 延迟分析可视化 ---\n",
    "try:\n",
    "    import matplotlib.pyplot as plt\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(10, 4))\n",
    "    \n",
    "    stages = list(result[\"stages\"].keys())\n",
    "    latencies = [result[\"stages\"][s][\"latency_ms\"] for s in stages]\n",
    "    colors = ['#c2553a', '#5a6b4a', '#2d2a26', '#c2553a']\n",
    "    \n",
    "    bars = ax.bar(stages, latencies, color=colors[:len(stages)])\n",
    "    ax.set_ylabel('延迟 (ms)')\n",
    "    ax.set_title('语音管道各环节延迟分析')\n",
    "    \n",
    "    for bar, lat in zip(bars, latencies):\n",
    "        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 5,\n",
    "                f'{lat:.0f}ms', ha='center', fontsize=10)\n",
    "    \n",
    "    ax.axhline(y=1500, color='red', linestyle='--', alpha=0.5, label='目标延迟 1500ms')\n",
    "    ax.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('voice_pipeline_latency.png', dpi=100, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    print(\"[OK] 延迟分析图已保存\")\n",
    "except ImportError:\n",
    "    print(\"[SKIP] matplotlib不可用\")\n",
    "\n",
    "print(\"\\n关键洞察:\")\n",
    "print(\"  1. LLM通常是延迟瓶颈 — 首token延迟(TTFT)最关键\")\n",
    "print(\"  2. 流式处理可大幅降低感知延迟\")\n",
    "print(\"  3. VAD虽然延迟低，但决定了整体体验的起点\")"
   ]
