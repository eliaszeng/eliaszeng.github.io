   "source": [
    "# === 14. DDP概念演示 ===\n",
    "# 用单进程模拟DDP的梯度同步过程\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"DDP 梯度同步模拟演示\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "\n",
    "# --- 模拟多GPU的DDP训练 ---\n",
    "def simulate_ddp_training(num_gpus: int = 4, num_steps: int = 5):\n",
    "    \"\"\"模拟DDP训练过程\"\"\"\n",
    "    \n",
    "    # 初始化: 所有GPU相同的模型参数\n",
    "    np.random.seed(42)\n",
    "    model_params = np.array([1.0, 2.0, 3.0])  # 简化: 3个参数\n",
    "    \n",
    "    # 每个GPU的参数副本\n",
    "    gpu_params = {i: model_params.copy() for i in range(num_gpus)}\n",
    "    learning_rate = 0.01\n",
    "    \n",
    "    print(f\"\\n模拟 {num_gpus} GPU DDP训练\")\n",
    "    print(f\"初始参数: {model_params}\")\n",
    "    print(f\"学习率: {learning_rate}\")\n",
    "    print(\"-\" * 50)\n",
    "    \n",
    "    for step in range(num_steps):\n",
    "        # Step 1: 每个GPU用各自的数据计算梯度\n",
    "        gpu_gradients = {}\n",
    "        for gpu_id in range(num_gpus):\n",
    "            # 模拟: 每个GPU看到不同数据，产生略有不同的梯度\n",
    "            noise = np.random.randn(3) * 0.1\n",
    "            true_grad = gpu_params[gpu_id] * 0.5  # 简化的梯度计算\n",
    "            gpu_gradients[gpu_id] = true_grad + noise\n",
    "        \n",
    "        # Step 2: AllReduce — 求所有GPU梯度的平均\n",
    "        all_grads = np.stack([gpu_gradients[g] for g in range(num_gpus)])\n",
    "        reduced_grad = np.mean(all_grads, axis=0)\n",
    "        \n",
    "        # Step 3: 每个GPU用相同的平均梯度更新参数\n",
    "        for gpu_id in range(num_gpus):\n",
    "            gpu_params[gpu_id] -= learning_rate * reduced_grad\n",
    "        \n",
    "        # 验证: 所有GPU参数相同\n",
    "        param_diffs = [np.max(np.abs(gpu_params[0] - gpu_params[g])) \n",
    "                       for g in range(1, num_gpus)]\n",
    "        \n",
    "        if step < 3 or step == num_steps - 1:\n",
    "            print(f\"Step {step+1}:\")\n",
    "            print(f\"  各GPU梯度: {[f'{np.linalg.norm(gpu_gradients[g]):.3f}' for g in range(num_gpus)]}\")\n",
    "            print(f\"  平均梯度: {np.linalg.norm(reduced_grad):.3f}\")\n",
    "            print(f\"  更新后参数: {gpu_params[0]}\")\n",
    "            print(f\"  GPU间参数差异: {max(param_diffs):.2e}\")\n",
    "        elif step == 3:\n",
    "            print(\"  ...\")\n",
    "    \n",
    "    return gpu_params\n",
    "\n",
    "\n",
    "# 运行DDP模拟\n",
    "final_params = simulate_ddp_training(num_gpus=4, num_steps=10)\n",
    "\n",
    "\n",
    "# --- 通信量分析 ---\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"DDP 通信量分析\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "def calc_ddp_communication(model_params_b: float, num_gpus: int,\n",
    "                           precision: str = \"FP16\") -> dict:\n",
    "    \"\"\"\n",
    "    计算DDP AllReduce的通信量\n",
    "    Ring AllReduce: 2 * (N-1)/N * model_size\n",
    "    \"\"\"\n",
    "    bytes_per_param = {\"FP32\": 4, \"FP16\": 2, \"INT8\": 1}\n",
    "    model_bytes = model_params_b * 1e9 * bytes_per_param[precision]\n",
    "    \n",
    "    # Ring AllReduce通信量\n",
    "    ring_comm = 2 * (num_gpus - 1) / num_gpus * model_bytes\n",
    "    \n",
    "    return {\n",
    "        \"model_size_gb\": model_bytes / 1e9,\n",
    "        \"ring_allreduce_gb\": ring_comm / 1e9,\n",
    "        \"comm_ratio\": 2 * (num_gpus - 1) / num_gpus,\n",
    "    }\n",
    "\n",
    "\n",
    "# 不同模型和GPU数量的通信量\n",
    "print(f\"\\n{'模型':10s} | {'GPU数':5s} | {'模型大小':10s} | {'AllReduce通信':14s} | {'通信比'}\")\n",
    "print(\"-\" * 65)\n",
    "\n",
    "for model_name, params_b in [(\"7B\", 7), (\"13B\", 13), (\"70B\", 70)]:\n",
    "    for gpus in [2, 4, 8]:\n",
    "        result = calc_ddp_communication(params_b, gpus)\n",
    "        print(f\"{model_name:10s} | {gpus:5d} | {result['model_size_gb']:8.1f} GB | {result['ring_allreduce_gb']:12.1f} GB | {result['comm_ratio']:.2f}\")\n",
    "\n",
    "\n",
    "# --- 梯度累积演示 ---\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"梯度累积演示\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "def demo_gradient_accumulation(accum_steps: int = 4):\n",
    "    \"\"\"演示梯度累积如何模拟大batch\"\"\"\n",
    "    \n",
    "    # 真实场景: batch_size=32, accum_steps=4 → 等效batch_size=128\n",
    "    micro_batch = 32\n",
    "    effective_batch = micro_batch * accum_steps\n",
    "    \n",
    "    print(f\"\\n微批次大小: {micro_batch}\")\n",
    "    print(f\"累积步数: {accum_steps}\")\n",
    "    print(f\"等效批次大小: {effective_batch}\")\n",
    "    print(f\"通信频率: 每{accum_steps}步做一次AllReduce\")\n",
    "    print(f\"通信量节省: {accum_steps}x (相比每步都同步)\")\n",
    "    \n",
    "    # 模拟累积过程\n",
    "    accumulated_grad = np.zeros(3)\n",
    "    np.random.seed(42)\n",
    "    \n",
    "    print(f\"\\n梯度累积过程:\")\n",
    "    for step in range(accum_steps):\n",
    "        mini_grad = np.random.randn(3)\n",
    "        accumulated_grad += mini_grad\n",
    "        print(f\"  Step {step+1}: 微批次梯度 norm={np.linalg.norm(mini_grad):.3f}, \"\n",
    "              f\"累积梯度 norm={np.linalg.norm(accumulated_grad):.3f}\")\n",
    "    \n",
    "    # 最后除以累积步数\n",
    "    final_grad = accumulated_grad / accum_steps\n",
    "    print(f\"  平均梯度 norm={np.linalg.norm(final_grad):.3f}\")\n",
    "    print(f\"  → 执行 optimizer.step() + AllReduce\")\n",
    "\n",
    "\n",
    "demo_gradient_accumulation(accum_steps=4)\n",
    "\n",
    "print(\"\\n关键洞察:\")\n",
    "print(\"  1. DDP通信量 ≈ 2 * 模型大小，与GPU数无关(Ring AllReduce)\")\n",
    "print(\"  2. 梯度累积可减少通信频率，以时间换空间\")\n",
    "print(\"  3. DDP接近线性加速(90%+), 但受限于最慢的GPU\")\n",
    "print(\"  4. FSDP通过分片参数进一步降低单卡显存需求\")"
   ]
