---
import projects from '../data/projects.json';

const active = projects.filter(p => p.status === 'active').length;
const total = projects.length;
const avgProgress = Math.round(projects.reduce((sum, p) => sum + p.progress, 0) / total);
---

<div class="grid grid-cols-3 gap-6 mb-14">
  <div class="reveal text-center py-6">
    <div class="font-display text-5xl font-bold text-terracotta mb-2">{active}</div>
    <div class="text-xs font-mono text-ink-faint tracking-[0.2em] uppercase">进行中</div>
  </div>
  <div class="reveal text-center py-6 border-x border-ink/[0.06]">
    <div class="font-display text-5xl font-bold text-ink mb-2">{total}</div>
    <div class="text-xs font-mono text-ink-faint tracking-[0.2em] uppercase">全部项目</div>
  </div>
  <div class="reveal text-center py-6">
    <div class="font-display text-5xl font-bold text-sage mb-2">{avgProgress}%</div>
    <div class="text-xs font-mono text-ink-faint tracking-[0.2em] uppercase">平均进度</div>
  </div>
</div>
