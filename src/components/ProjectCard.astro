---
interface Props {
  name: string;
  description: string;
  status: string;
  progress: number;
  tags: string[];
  link?: string;
  startDate: string;
}

const { name, description, status, progress, tags, link, startDate } = Astro.props;

const statusMap: Record<string, { label: string; dot: string }> = {
  active: { label: '进行中', dot: 'bg-sage' },
  planned: { label: '计划中', dot: 'bg-ink-faint' },
  completed: { label: '已完成', dot: 'bg-terracotta' },
  paused: { label: '已暂停', dot: 'bg-ink-faint' },
};

const s = statusMap[status] || statusMap.planned;
---

<article class="group bg-paper rounded-2xl p-7 shadow-sm hover:shadow-lg transition-all duration-500 hover:-translate-y-1 border border-ink/[0.04]">
  <div class="flex items-start justify-between mb-4">
    <h3 class="font-display text-xl font-bold text-ink group-hover:text-terracotta transition-colors duration-300 leading-tight">
      {link ? <a href={link} target="_blank" class="hover:underline decoration-terracotta/30 underline-offset-4">{name}</a> : name}
    </h3>
    <span class="flex items-center gap-2 text-xs font-mono text-ink-light tracking-wider uppercase shrink-0 ml-4">
      <span class:list={["w-1.5 h-1.5 rounded-full", s.dot]}></span>
      {s.label}
    </span>
  </div>

  <p class="text-ink-light text-[15px] leading-relaxed mb-6">{description}</p>

  <!-- Progress bar -->
  <div class="mb-5">
    <div class="h-[3px] bg-cream-dark rounded-full overflow-hidden">
      <div
        class="h-full bg-ink rounded-full transition-all duration-1000 ease-out"
        style={`width: ${progress}%`}
      ></div>
    </div>
    <div class="flex justify-between mt-2 text-xs font-mono text-ink-faint">
      <span>{progress}%</span>
    </div>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map(tag => (
      <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-cream text-ink-light tracking-wider">
        {tag}
      </span>
    ))}
  </div>

  <div class="text-xs font-mono text-ink-faint tracking-wider">
    started {startDate}
  </div>
</article>
