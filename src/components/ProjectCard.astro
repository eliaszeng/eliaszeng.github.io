---
interface Props {
  name: string;
  description: string;
  status: string;
  progress: number;
  tags: string[];
  link?: string;
  startDate: string;
}

const { name, description, status, progress, tags, link, startDate } = Astro.props;

const statusMap: Record<string, { label: string; color: string; dot: string }> = {
  active: { label: '进行中', color: 'text-green-400', dot: 'bg-green-400' },
  planned: { label: '计划中', color: 'text-yellow-400', dot: 'bg-yellow-400' },
  completed: { label: '已完成', color: 'text-neon-blue', dot: 'bg-neon-blue' },
  paused: { label: '已暂停', color: 'text-gray-500', dot: 'bg-gray-500' },
};

const s = statusMap[status] || statusMap.planned;
---

<div class="group relative bg-gray-900/60 border border-gray-800 rounded-xl p-6 hover:border-neon-blue/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,212,255,0.08)]">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-semibold text-white group-hover:text-neon-blue transition-colors">
      {link ? <a href={link} target="_blank">{name} <span class="text-gray-600 text-sm">↗</span></a> : name}
    </h3>
    <span class:list={["flex items-center gap-1.5 text-xs font-mono", s.color]}>
      <span class:list={["w-2 h-2 rounded-full animate-pulse", s.dot]}></span>
      {s.label}
    </span>
  </div>

  <p class="text-gray-400 text-sm mb-4 leading-relaxed">{description}</p>

  <!-- Progress bar -->
  <div class="mb-4">
    <div class="flex justify-between text-xs font-mono text-gray-500 mb-1.5">
      <span>progress</span>
      <span>{progress}%</span>
    </div>
    <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">
      <div
        class="h-full rounded-full bg-gradient-to-r from-neon-blue to-neon-purple transition-all duration-1000"
        style={`width: ${progress}%`}
      ></div>
    </div>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {tags.map(tag => (
      <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-gray-800 text-gray-400 border border-gray-700">
        {tag}
      </span>
    ))}
  </div>

  <div class="mt-3 text-xs font-mono text-gray-600">
    started {startDate}
  </div>
</div>
