---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="交易日记 — Elias Zeng" activeNav="trading">

  {/* Page header */}
  <div class="mb-12">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-faint mb-3">Trading Journal</p>
    <h1 class="font-display text-5xl lg:text-6xl font-bold leading-tight">
      交易<span class="text-terracotta italic">日记</span>
    </h1>
    <p class="mt-4 text-ink-light max-w-xl">记录交易操作与选股建议，K线复盘，数据由后端自动生成。</p>
  </div>

  {/* Stats bar */}
  <div id="stats-bar" class="grid grid-cols-3 gap-6 mb-12 reveal">
    <div class="text-center py-4">
      <div class="font-display text-4xl font-bold text-terracotta" id="stat-weekly">0</div>
      <div class="font-mono text-xs uppercase tracking-wider text-ink-faint mt-1">本周交易</div>
    </div>
    <div class="text-center py-4 border-x border-ink/[0.06]">
      <div class="font-display text-4xl font-bold" id="stat-total">0</div>
      <div class="font-mono text-xs uppercase tracking-wider text-ink-faint mt-1">总记录</div>
    </div>
    <div class="text-center py-4">
      <div class="font-display text-4xl font-bold text-sage" id="stat-tips">0</div>
      <div class="font-mono text-xs uppercase tracking-wider text-ink-faint mt-1">朋友建议</div>
    </div>
  </div>

  <div class="h-px bg-ink/[0.08] mb-12"></div>

  {/* Tab switcher + Filters */}
  <div class="flex flex-wrap items-center gap-3 mb-4 reveal">
    <button data-tab="trades" class="tab-btn font-mono text-xs px-4 py-1.5 rounded-full bg-ink text-cream transition-colors">交易记录</button>
    <button data-tab="advice" class="tab-btn font-mono text-xs px-4 py-1.5 rounded-full bg-cream text-ink-light hover:bg-cream-dark transition-colors">朋友建议</button>
    <div class="flex-1"></div>
    <span class="font-mono text-xs text-ink-faint">日期</span>
    <button data-range="today" class="range-btn font-mono text-xs px-3 py-1 rounded-full bg-cream text-ink-light border border-ink/10 hover:bg-cream-dark">今天</button>
    <button data-range="7d" class="range-btn font-mono text-xs px-3 py-1 rounded-full bg-cream text-ink-light border border-ink/10 hover:bg-cream-dark">近7天</button>
    <button data-range="30d" class="range-btn font-mono text-xs px-3 py-1 rounded-full bg-cream text-ink-light border border-ink/10 hover:bg-cream-dark">近30天</button>
    <button data-range="all" class="range-btn font-mono text-xs px-3 py-1 rounded-full bg-ink text-cream">全部</button>
  </div>

  {/* Content area */}
  <div id="content-area" class="space-y-4">
    <div id="empty-state" class="text-center py-20 text-ink-faint">
      <p class="font-display text-2xl mb-2">暂无数据</p>
      <p class="text-sm">数据由后端 Python 脚本生成，请等待更新</p>
    </div>
  </div>

  {/* Image lightbox */}
  <div id="lightbox" class="fixed inset-0 z-50 bg-ink/80 backdrop-blur-sm hidden items-center justify-center p-8 cursor-pointer">
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg" />
  </div>

</BaseLayout>

<script>
  // --- State ---
  let trades = [];
  let advice = [];
  let currentTab = 'trades';
  let currentRange = 'all';

  // --- DOM refs ---
  const contentArea = document.getElementById('content-area');
  const emptyState = document.getElementById('empty-state');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');

  // --- Links ---
  function getStockLinks(code) {
    if (!code) return {};
    const c = code.replace(/\D/g, '');
    const ths = `https://stockpage.10jqka.com.cn/${c}/`;
    const prefix = c.startsWith('6') ? 'sh'
      : c.startsWith('4') || c.startsWith('8') ? 'bj' : 'sz';
    const east = `https://quote.eastmoney.com/${prefix}${c}.html`;
    return { ths, east };
  }

  // --- Date helpers ---
  function formatFullDate(iso) {
    const d = new Date(iso);
    return `${d.getFullYear()}-${(d.getMonth()+1).toString().padStart(2,'0')}-${d.getDate().toString().padStart(2,'0')} ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
  }

  function isInRange(dateStr, range) {
    if (range === 'all') return true;
    const d = new Date(dateStr).getTime();
    const now = Date.now();
    if (range === 'today') {
      const todayStart = new Date(); todayStart.setHours(0,0,0,0);
      return d >= todayStart.getTime();
    }
    if (range === '7d') return d >= now - 7 * 86400000;
    if (range === '30d') return d >= now - 30 * 86400000;
    return true;
  }

  function groupByDate(items, dateField) {
    const groups = {};
    for (const item of items) {
      const key = new Date(item[dateField]).toISOString().slice(0, 10);
      if (!groups[key]) groups[key] = [];
      groups[key].push(item);
    }
    return groups;
  }

  function labelForDate(dateKey) {
    const d = new Date(dateKey + 'T00:00:00');
    const now = new Date();
    const diff = Math.floor((now - d) / 86400000);
    if (diff === 0) return '今天';
    if (diff === 1) return '昨天';
    if (diff < 7) return `${diff}天前`;
    return `${d.getMonth() + 1}月${d.getDate()}日`;
  }

  // --- Render trades ---
  function renderTrades() {
    const filtered = trades.filter(t => isInRange(t.tradeTime, currentRange));
    if (filtered.length === 0) {
      contentArea.innerHTML = '';
      contentArea.appendChild(emptyState);
      emptyState.querySelector('p').textContent = '暂无交易记录';
      emptyState.classList.remove('hidden');
      return;
    }

    emptyState.classList.add('hidden');
    const groups = groupByDate(filtered, 'tradeTime');
    let html = '';

    for (const [dateKey, items] of Object.entries(groups)) {
      html += `<div class="mb-6">`;
      html += `<div class="font-mono text-xs text-ink-faint mb-3">${labelForDate(dateKey)}</div>`;

      for (const t of items) {
        const isBuy = t.direction === 'buy';
        const links = getStockLinks(t.stockCode);
        const accentClass = isBuy ? 'border-l-sage' : 'border-l-terracotta';
        const badge = isBuy
          ? `<span class="font-mono text-xs px-2 py-0.5 rounded-full bg-sage/10 text-sage">买入</span>`
          : `<span class="font-mono text-xs px-2 py-0.5 rounded-full bg-terracotta/10 text-terracotta">卖出</span>`;

        const tagsHtml = t.tags?.length
          ? `<div class="flex flex-wrap gap-1.5 mt-2">${t.tags.map(tag => `<span class="font-mono text-xs px-2.5 py-0.5 rounded-full bg-cream text-ink-light">${tag}</span>`).join('')}</div>`
          : '';

        const chartHtml = t.chartPath
          ? `<div class="mt-3"><img src="${t.chartPath}" alt="K线图" class="rounded-lg border border-ink/10 cursor-pointer hover:opacity-80 transition-opacity chart-img w-full max-w-md" /></div>`
          : '';

        const reasonHtml = t.reason
          ? `<p class="text-sm text-ink-light mt-2 leading-relaxed">${t.reason}</p>`
          : '';

        html += `
          <div class="bg-paper rounded-xl p-5 shadow-sm border border-ink/[0.04] border-l-2 ${accentClass} hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 mb-2">
                  ${t.stockName ? `<span class="font-display text-2xl font-bold tracking-tight text-ink">${t.stockName}</span>` : ''}
                  ${t.stockCode ? `<a href="${links.ths}" target="_blank" rel="noopener" class="font-mono text-sm font-bold px-2 py-0.5 rounded bg-terracotta/10 text-terracotta hover:bg-terracotta/20 transition-colors">${t.stockCode}</a>` : ''}
                </div>
                <div class="flex items-center gap-3">
                  ${badge}
                  <span class="font-mono text-xs text-ink-faint">${formatFullDate(t.tradeTime)}</span>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center gap-2">
              <span class="font-mono text-sm text-ink font-bold">${t.price?.toFixed(2) ?? '-'}</span>
              ${t.quantity ? `<span class="font-mono text-xs text-ink-faint">&times;${t.quantity}</span>` : ''}
              ${t.amount ? `<span class="font-mono text-xs text-ink-faint ml-2">= ${t.amount.toLocaleString()}</span>` : ''}
            </div>
            ${reasonHtml}
            <div class="flex gap-2 mt-2">
              <a href="${links.ths}" target="_blank" rel="noopener" class="font-mono text-xs px-2 py-0.5 rounded bg-cream text-ink-light hover:text-terracotta transition-colors">同花顺 &nearr;</a>
              <a href="${links.east}" target="_blank" rel="noopener" class="font-mono text-xs px-2 py-0.5 rounded bg-cream text-ink-light hover:text-terracotta transition-colors">东方财富 &nearr;</a>
            </div>
            ${tagsHtml}
            ${chartHtml}
          </div>
        `;
      }
      html += `</div>`;
    }

    contentArea.innerHTML = html;
    bindChartClicks();
  }

  // --- Render advice ---
  function renderAdvice() {
    const filtered = advice.filter(a => isInRange(a.createdAt, currentRange));
    if (filtered.length === 0) {
      contentArea.innerHTML = '';
      contentArea.appendChild(emptyState);
      emptyState.querySelector('p').textContent = '暂无建议记录';
      emptyState.classList.remove('hidden');
      return;
    }

    emptyState.classList.add('hidden');
    const groups = groupByDate(filtered, 'createdAt');
    let html = '';

    for (const [dateKey, items] of Object.entries(groups)) {
      html += `<div class="mb-6">`;
      html += `<div class="font-mono text-xs text-ink-faint mb-3">${labelForDate(dateKey)}</div>`;

      for (const a of items) {
        const links = getStockLinks(a.stockCode);
        const isBuy = a.direction === 'buy';
        const dirBadge = a.direction === 'buy'
          ? `<span class="font-mono text-xs px-2 py-0.5 rounded-full bg-sage/10 text-sage">买入</span>`
          : a.direction === 'sell'
            ? `<span class="font-mono text-xs px-2 py-0.5 rounded-full bg-terracotta/10 text-terracotta">卖出</span>`
            : a.direction === 'hold'
              ? `<span class="font-mono text-xs px-2 py-0.5 rounded-full bg-ink/[0.06] text-ink-light">持有</span>`
              : '';

        const chartHtml = a.chartPath
          ? `<div class="mt-3"><img src="${a.chartPath}" alt="K线图" class="rounded-lg border border-ink/10 cursor-pointer hover:opacity-80 transition-opacity chart-img w-full max-w-md" /></div>`
          : '';

        const reasonHtml = a.reason
          ? `<p class="text-sm text-ink-light mt-2 leading-relaxed">${a.reason}</p>`
          : '';

        html += `
          <div class="bg-paper rounded-xl p-5 shadow-sm border border-ink/[0.04] border-l-2 border-l-ink-faint hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 mb-2">
                  ${a.stockName ? `<span class="font-display text-2xl font-bold tracking-tight text-ink">${a.stockName}</span>` : ''}
                  ${a.stockCode ? `<a href="${links.ths}" target="_blank" rel="noopener" class="font-mono text-sm font-bold px-2 py-0.5 rounded bg-terracotta/10 text-terracotta hover:bg-terracotta/20 transition-colors">${a.stockCode}</a>` : ''}
                </div>
                <div class="flex items-center gap-3">
                  ${dirBadge}
                  ${a.source ? `<span class="font-mono text-xs px-2 py-0.5 rounded-full bg-ink/[0.06] text-ink-light">${a.source}</span>` : ''}
                  <span class="font-mono text-xs text-ink-faint">${formatFullDate(a.createdAt)}</span>
                </div>
              </div>
            </div>
            ${a.keyPrice ? `<div class="mt-3"><span class="font-mono text-xs text-ink-faint">关键价位</span> <span class="font-mono text-sm text-ink font-bold">${a.keyPrice.toFixed(2)}</span></div>` : ''}
            ${reasonHtml}
            <div class="flex gap-2 mt-2">
              <a href="${links.ths}" target="_blank" rel="noopener" class="font-mono text-xs px-2 py-0.5 rounded bg-cream text-ink-light hover:text-terracotta transition-colors">同花顺 &nearr;</a>
              <a href="${links.east}" target="_blank" rel="noopener" class="font-mono text-xs px-2 py-0.5 rounded bg-cream text-ink-light hover:text-terracotta transition-colors">东方财富 &nearr;</a>
            </div>
            ${chartHtml}
          </div>
        `;
      }
      html += `</div>`;
    }

    contentArea.innerHTML = html;
    bindChartClicks();
  }

  // --- Lightbox ---
  function bindChartClicks() {
    contentArea.querySelectorAll('.chart-img').forEach(img => {
      img.addEventListener('click', () => {
        lightboxImg.src = img.src;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
      });
    });
  }

  lightbox.addEventListener('click', () => {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
  });

  // --- Render dispatcher ---
  function render() {
    if (currentTab === 'trades') {
      renderTrades();
    } else {
      renderAdvice();
    }
  }

  // --- Stats ---
  function updateStats() {
    const now = Date.now();
    const weekAgo = now - 7 * 86400000;
    const weekly = trades.filter(t => new Date(t.tradeTime).getTime() >= weekAgo).length;

    document.getElementById('stat-weekly').textContent = weekly;
    document.getElementById('stat-total').textContent = trades.length;
    document.getElementById('stat-tips').textContent = advice.length;
  }

  // --- Tab buttons ---
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentTab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.className = b === btn
          ? 'tab-btn font-mono text-xs px-4 py-1.5 rounded-full bg-ink text-cream transition-colors'
          : 'tab-btn font-mono text-xs px-4 py-1.5 rounded-full bg-cream text-ink-light hover:bg-cream-dark transition-colors';
      });
      render();
    });
  });

  // --- Range buttons ---
  document.querySelectorAll('.range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentRange = btn.dataset.range;
      document.querySelectorAll('.range-btn').forEach(b => {
        b.className = b === btn
          ? 'range-btn font-mono text-xs px-3 py-1 rounded-full bg-ink text-cream'
          : 'range-btn font-mono text-xs px-3 py-1 rounded-full bg-cream text-ink-light border border-ink/10 hover:bg-cream-dark';
      });
      render();
    });
  });

  // --- Load data ---
  async function loadData() {
    try {
      const [tradesResp, adviceResp] = await Promise.all([
        fetch('/trading/data/trades.json'),
        fetch('/trading/data/advice.json'),
      ]);
      if (tradesResp.ok) trades = await tradesResp.json();
      if (adviceResp.ok) advice = await adviceResp.json();

      trades.sort((a, b) => new Date(b.tradeTime) - new Date(a.tradeTime));
      advice.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

      updateStats();
      render();
    } catch (e) {
      console.error('Failed to load trading data:', e);
    }
  }

  loadData();
</script>