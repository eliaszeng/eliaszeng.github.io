---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import StatsBar from '../components/StatsBar.astro';
import projects from '../data/projects.json';

const activeProjects = projects.filter(p => p.status === 'active');
---

<BaseLayout title="Elias Zeng - Dashboard" activeNav="home">
  <!-- Hero -->
  <section class="mb-16">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 rounded-full bg-gradient-to-br from-neon-blue to-neon-purple flex items-center justify-center text-2xl font-bold font-mono animate-float">
        E
      </div>
      <div>
        <h1 class="text-3xl font-bold text-white">Elias Zeng</h1>
        <p class="text-gray-400 font-mono text-sm">builder · learner · explorer</p>
      </div>
    </div>
    <p class="text-gray-300 leading-relaxed max-w-2xl">
      在这里记录我正在做的事情。关注大模型应用、交易系统、以及各种有意思的 side project。
    </p>
  </section>

  <StatsBar />

  <!-- Active Projects -->
  <section>
    <h2 class="text-xl font-semibold text-white mb-6 font-mono flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      当前进行中
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {activeProjects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  <!-- Quick links -->
  <section class="mt-16">
    <h2 class="text-xl font-semibold text-white mb-6 font-mono">快速链接</h2>
    <div class="flex flex-wrap gap-4">
      <a href="/projects" class="px-5 py-3 bg-gray-900/60 border border-gray-800 rounded-lg text-sm font-mono text-gray-300 hover:border-neon-blue/40 hover:text-neon-blue transition-all">
        所有项目 →
      </a>
      <a href="/news" class="px-5 py-3 bg-gray-900/60 border border-gray-800 rounded-lg text-sm font-mono text-gray-300 hover:border-neon-purple/40 hover:text-neon-purple transition-all">
        科技资讯 →
      </a>
      <a href="https://github.com/eliaszeng" target="_blank" class="px-5 py-3 bg-gray-900/60 border border-gray-800 rounded-lg text-sm font-mono text-gray-300 hover:border-neon-pink/40 hover:text-neon-pink transition-all">
        GitHub ↗
      </a>
    </div>
  </section>
</BaseLayout>
