---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const statusOrder = ['active', 'planned', 'paused', 'completed'];
const sorted = [...projects].sort((a, b) => statusOrder.indexOf(a.status) - statusOrder.indexOf(b.status));
---

<BaseLayout title="项目看板 - Elias Zeng" activeNav="projects">
  <h1 class="text-2xl font-bold text-white mb-2 font-mono">项目看板</h1>
  <p class="text-gray-400 mb-10">所有项目的进度和状态一览</p>

  <!-- Filter tabs -->
  <div class="flex gap-3 mb-8">
    <button class="filter-btn active px-4 py-1.5 rounded-full text-sm font-mono border border-neon-blue/50 text-neon-blue bg-neon-blue/10" data-filter="all">全部</button>
    <button class="filter-btn px-4 py-1.5 rounded-full text-sm font-mono border border-gray-700 text-gray-400 hover:border-gray-500 transition-colors" data-filter="active">进行中</button>
    <button class="filter-btn px-4 py-1.5 rounded-full text-sm font-mono border border-gray-700 text-gray-400 hover:border-gray-500 transition-colors" data-filter="planned">计划中</button>
    <button class="filter-btn px-4 py-1.5 rounded-full text-sm font-mono border border-gray-700 text-gray-400 hover:border-gray-500 transition-colors" data-filter="completed">已完成</button>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="project-grid">
    {sorted.map(project => (
      <div class="project-item" data-status={project.status}>
        <ProjectCard {...project} />
      </div>
    ))}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active button
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active', 'border-neon-blue/50', 'text-neon-blue', 'bg-neon-blue/10');
        b.classList.add('border-gray-700', 'text-gray-400');
      });
      btn.classList.add('active', 'border-neon-blue/50', 'text-neon-blue', 'bg-neon-blue/10');
      btn.classList.remove('border-gray-700', 'text-gray-400');

      const filter = btn.dataset.filter;
      document.querySelectorAll('.project-item').forEach(item => {
        if (filter === 'all' || item.dataset.status === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
