---
interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Elias Zeng - 项目追踪与科技资讯" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen font-sans">
    <!-- Background grid -->
    <div class="fixed inset-0 bg-[linear-gradient(rgba(0,212,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,212,255,0.03)_1px,transparent_1px)] bg-[size:50px_50px] pointer-events-none"></div>

    <!-- Nav -->
    <nav class="relative z-10 border-b border-gray-800/50 backdrop-blur-sm bg-gray-950/80 sticky top-0">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold font-mono text-neon-blue hover:text-neon-purple transition-colors">
          &lt;elias /&gt;
        </a>
        <div class="flex gap-6 text-sm font-mono">
          <a href="/" class:list={["transition-colors", activeNav === 'home' ? "text-neon-blue" : "text-gray-400 hover:text-white"]}>首页</a>
          <a href="/projects" class:list={["transition-colors", activeNav === 'projects' ? "text-neon-blue" : "text-gray-400 hover:text-white"]}>项目</a>
          <a href="/news" class:list={["transition-colors", activeNav === 'news' ? "text-neon-blue" : "text-gray-400 hover:text-white"]}>资讯</a>
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main class="relative z-10 max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-gray-800/50 mt-20">
      <div class="max-w-6xl mx-auto px-6 py-6 text-center text-gray-600 text-sm font-mono">
        Built with Astro & Tailwind · {new Date().getFullYear()} Elias Zeng
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }
  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
